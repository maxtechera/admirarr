def cmd_find(query):
    print_banner()
    print(bold(f"\n  Radarr Interactive Search: {query}\n"))
    movies = api_get("radarr", "api/v3/movie")
    if not movies:
        print(f"  {err('Cannot reach Radarr')}")
        return
    match = None
    for m in movies:
        if query.lower() in m.get("title", "").lower():
            match = m
            break
    if not match:
        print(f"  {err(f'Movie not found in Radarr: {query}')}")
        return

    print(f"  Searching releases for: {bold(match['title'])} (ID: {match['id']})")
    releases = api_get("radarr", f"api/v3/release", {"movieId": str(match["id"])}, timeout=30)
    if not releases or len(releases) == 0:
        print(f"  {err('No releases found')}")
        return
    for i, r in enumerate(releases[:10], 1):
        quality = r.get("quality", {}).get("quality", {}).get("name", "?")
        size = fmt_size(r.get("size", 0))
        seeders = r.get("seeders", 0)
        rejected = r.get("rejected", False)
        status = err("REJECTED") if rejected else ok("OK")
        title = r.get("title", "?")[:65]
        print(f"  {dim(f'{i:>2}.')} {status} {title}")
        print(f"      {quality} | {size} | Seeds: {seeders}")
        if rejected and r.get("rejections"):
            for rej in r["rejections"][:2]:
                print(f"      {warn(rej)}")
    print()

def cmd_indexers():
    print_banner()
    print(bold("\n  Prowlarr — Indexers\n"))
    data = api_get("prowlarr", "api/v1/indexer")
    if not data:
        print(f"  {err('Cannot reach Prowlarr')}")
        return
    statuses = api_get("prowlarr", "api/v1/indexerstatus") or []
    failed_ids = {s.get("indexerId") for s in statuses if s.get("mostRecentFailure")}

    for idx in data:
        enabled = idx.get("enable", False)
        iid = idx.get("id")
        name = idx.get("name", "?")
        proto = idx.get("protocol", "?")
        if not enabled:
            status = dim("DISABLED")
        elif iid in failed_ids:
            status = err("FAILING")
        else:
            status = ok("OK")
        print(f"  {status:>20}  {name} ({proto})")
    print(f"\n  {dim(f'{len(data)} indexers total')}\n")

def cmd_scan():
    print_banner()
    print(bold("\n  Triggering Plex Library Scan...\n"))
    key = get_key("plex")
    if not key:
        print(f"  {err('No Plex token found')}")
        return
    try:
        url = f"http://{WIN_HOST}:32400/library/sections?X-Plex-Token={key}"
        with urllib.request.urlopen(url, timeout=5) as resp:
            root = ET.fromstring(resp.read())
        for d in root.findall(".//Directory"):
            section_id = d.get("key")
            title = d.get("title")
            scan_url = f"http://{WIN_HOST}:32400/library/sections/{section_id}/refresh?X-Plex-Token={key}"
            req = urllib.request.Request(scan_url, method="POST", data=b"")
            urllib.request.urlopen(req, timeout=5)
            print(f"  {ok('●')} Scanning: {title}")
    except Exception as e:
        print(f"  {err(f'Failed: {e}')}")
    print()

