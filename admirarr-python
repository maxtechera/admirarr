# ── API Keys ─────────────────────────────────────────────────────────────────

_key_cache = {}

def _read_xml_key(path):
    try:
        with open(path) as f:
            content = f.read()
        m = re.search(r'<ApiKey>([^<]+)</ApiKey>', content)
        return m.group(1) if m else None
    except Exception:
        return None

def _read_plex_token():
    plex_pref = "/mnt/c/Users/Max/AppData/Local/Plex/Plex Media Server/Preferences.xml"
    try:
        with open(plex_pref) as f:
            content = f.read()
        m = re.search(r'PlexOnlineToken="([^"]+)"', content)
        return m.group(1) if m else None
    except Exception:
        return None

def _read_seerr_key():
    try:
        result = subprocess.run(
            ["docker", "exec", "seerr", "cat", "/app/config/settings.json"],
            capture_output=True, text=True, timeout=5
        )
        data = json.loads(result.stdout)
        return data.get("main", {}).get("apiKey")
    except Exception:
        return None

def get_key(service):
    if service in _key_cache:
        return _key_cache[service]

    key = None
    if service == "sonarr":
        key = _read_xml_key("/mnt/c/ProgramData/Sonarr/config.xml")
    elif service == "radarr":
        key = _read_xml_key("/mnt/c/ProgramData/Radarr/config.xml")
    elif service == "prowlarr":
        key = _read_xml_key("/mnt/c/ProgramData/Prowlarr/config.xml")
    elif service == "plex":
        key = _read_plex_token()
    elif service == "seerr":
        key = _read_seerr_key()
    elif service == "tautulli":
        for path in [
            "/mnt/c/ProgramData/Tautulli/config.ini",
            "/mnt/c/Users/Max/AppData/Local/Tautulli/config.ini",
            "/mnt/c/Users/Max/AppData/Roaming/Tautulli/config.ini",
        ]:
            try:
                with open(path) as f:
                    for line in f:
                        if line.strip().startswith("api_key"):
                            key = line.split("=", 1)[1].strip()
                            break
            except Exception:
                pass

    if key:
        _key_cache[service] = key
    return key

# ── HTTP Helpers ─────────────────────────────────────────────────────────────

def _url(service, endpoint):
    svc = SERVICES[service]
    return f"http://{svc['host']}:{svc['port']}/{endpoint}"

def api_get(service, endpoint, params=None, timeout=5):
    svc = SERVICES[service]
    key = get_key(service)
    url_params = params or {}

    if service in ("sonarr", "radarr", "prowlarr") and key:
        url_params["apikey"] = key

    query = urllib.parse.urlencode(url_params) if url_params else ""
    url = _url(service, endpoint)
    if query:
        url += f"?{query}"

    req = urllib.request.Request(url)
    if service == "seerr" and key:
        req.add_header("X-Api-Key", key)
    if service == "plex" and key:
        url += f"{'&' if '?' in url else '?'}X-Plex-Token={key}"
        req = urllib.request.Request(url)

    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            data = resp.read().decode()
            try:
                return json.loads(data)
            except json.JSONDecodeError:
                return data
    except Exception:
        return None

def api_post(service, endpoint, body=None, params=None, timeout=10):
    svc = SERVICES[service]
    key = get_key(service)
    url_params = params or {}

    if service in ("sonarr", "radarr", "prowlarr") and key:
        url_params["apikey"] = key

    query = urllib.parse.urlencode(url_params) if url_params else ""
    url = _url(service, endpoint)
    if query:
        url += f"?{query}"

    payload = json.dumps(body).encode() if body else b""
    req = urllib.request.Request(url, data=payload, method="POST")
    req.add_header("Content-Type", "application/json")
    if service == "seerr" and key:
        req.add_header("X-Api-Key", key)
    if service == "plex" and key:
        url += f"{'&' if '?' in url else '?'}X-Plex-Token={key}"
        req = urllib.request.Request(url, data=payload, method="POST")

    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            data = resp.read().decode()
            try:
                return json.loads(data)
            except json.JSONDecodeError:
                return data
    except Exception:
        return None

def check_reachable(service, timeout=3):
    svc = SERVICES[service]
    key = get_key(service)
    endpoints = {
        "plex": "identity",
        "qbittorrent": "api/v2/app/version",
        "prowlarr": f"api/v1/health?apikey={key or ''}",
        "sonarr": f"api/v3/health?apikey={key or ''}",
        "radarr": f"api/v3/health?apikey={key or ''}",
        "tautulli": f"api/v2?apikey={key or ''}&cmd=status",
        "seerr": "api/v1/status",
        "bazarr": "",
        "organizr": "",
        "flaresolverr": "",
    }
    url = _url(service, endpoints.get(service, ""))
    try:
        req = urllib.request.Request(url)
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            return resp.status == 200
    except Exception:
        return False

def fmt_size(bytes_val):
    if not bytes_val:
        return "0 GB"
    gb = bytes_val / 1073741824
    if gb >= 1024:
        return f"{gb / 1024:.2f} TB"
    return f"{gb:.2f} GB"

