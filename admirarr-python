    if service not in ("sonarr", "radarr"):
        print(f"  {err('Logs only available for sonarr or radarr')}")
        return
    print_banner()
    print(bold(f"\n  {service.title()} — Recent Logs\n"))
    ver = SERVICES[service]["api_ver"]
    data = api_get(service, f"api/{ver}/log", {"pageSize": "20", "sortDirection": "descending", "sortKey": "time"})
    if not data or "records" not in data:
        print(f"  {err(f'Cannot get {service} logs')}")
        return
    for rec in data["records"]:
        level = rec.get("level", "?")
        msg = rec.get("message", "")[:100]
        t = rec.get("time", "")[:19]
        color = err if level == "error" else (warn if level == "warn" else dim)
        print(f"  {dim(t)} {color(level):>8}  {msg}")
    print()

