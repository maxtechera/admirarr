def cmd_status():
    print_banner()
    print()

    # Services with response times
    print(bold("  Fleet Status"))
    print(f"  {C.DIM}{'━' * 50}{C.RESET}")
    service_up = {}
    for name in SERVICES:
        t0 = _time.time()
        up = check_reachable(name)
        ms = (_time.time() - t0) * 1000
        service_up[name] = up
        svc = SERVICES[name]
        port = svc["port"]
        svc_type = "win" if svc["type"] == "windows" else "docker"
        if up:
            status = ok("●")
            latency = dim(f"{ms:.0f}ms")
        else:
            status = err("○")
            latency = err("down")
        print(f"  {status} {name:<15} {dim(f':{port}'):<14} {latency}")

    # Library counts
    print(bold("\n  Library"))
    print(f"  {C.DIM}{'━' * 50}{C.RESET}")
    movies = api_get("radarr", "api/v3/movie") if service_up.get("radarr") else None
    series = api_get("sonarr", "api/v3/series") if service_up.get("sonarr") else None
    if movies and isinstance(movies, list):
        have = sum(1 for m in movies if m.get("hasFile"))
        missing = sum(1 for m in movies if m.get("monitored") and not m.get("hasFile"))
        total_size = sum(m.get("sizeOnDisk", 0) for m in movies)
        miss_str = err(f"{missing} missing") if missing else ok("0 missing")
        print(f"  {gold('Movies')}     {len(movies)} total, {ok(f'{have} on disk')}, {miss_str}  {dim(fmt_size(total_size))}")
    else:
        print(f"  {gold('Movies')}     {dim('Radarr unavailable')}")
    if series and isinstance(series, list):
        total_eps = sum(s.get("statistics", {}).get("episodeCount", 0) for s in series)
        have_eps = sum(s.get("statistics", {}).get("episodeFileCount", 0) for s in series)
        total_size = sum(s.get("statistics", {}).get("sizeOnDisk", 0) for s in series)
        print(f"  {gold('TV Shows')}   {len(series)} shows, {ok(f'{have_eps}/{total_eps} episodes')}  {dim(fmt_size(total_size))}")
    else:
        print(f"  {gold('TV Shows')}   {dim('Sonarr unavailable')}")

    # Health
    print(bold("\n  Health"))
    print(f"  {C.DIM}{'━' * 50}{C.RESET}")
    has_issues = False
    for svc in ("radarr", "sonarr", "prowlarr"):
        if not service_up.get(svc):
            continue
        ver = SERVICES[svc].get("api_ver", "v3")
        data = api_get(svc, f"api/{ver}/health")
        if data and isinstance(data, list) and len(data) > 0:
            for item in data:
                has_issues = True
                level = err("ERROR") if item.get("type") == "error" else warn("WARN")
                print(f"  {level} {dim(f'[{svc}]')} {item.get('message', 'Unknown')[:65]}")
    if not has_issues:
        print(f"  {ok('●')} All services healthy")

    # Download Queues
    print(bold("\n  Queues"))
    print(f"  {C.DIM}{'━' * 50}{C.RESET}")
    for svc in ("radarr", "sonarr"):
        if not service_up.get(svc):
            print(f"  {dim(f'[{svc}] unavailable')}")
            continue
        ver = SERVICES[svc].get("api_ver", "v3")
        data = api_get(svc, f"api/{ver}/queue", {"pageSize": "50"})
        total = data.get("totalRecords", 0) if data else 0
        if total > 0:
            for rec in data.get("records", [])[:5]:
                state = rec.get("trackedDownloadState", "unknown")
                color = ok(state) if state == "downloading" else (warn(state) if state == "importPending" else err(state))
                print(f"  {dim(f'[{svc}]')} {color}  {rec.get('title', '?')[:50]}")
            if total > 5:
                print(f"  {dim(f'[{svc}] ... and {total - 5} more')}")
        else:
            print(f"  {dim(f'[{svc}] Empty')}")

    # Active torrents summary
    if service_up.get("qbittorrent"):
        try:
            url = f"http://{WIN_HOST}:8080/api/v2/torrents/info"
            with urllib.request.urlopen(url, timeout=5) as resp:
                torrents = json.loads(resp.read().decode())
            downloading = [t for t in torrents if t.get("state") in ("downloading", "stalledDL", "forcedDL", "metaDL")]
            seeding = [t for t in torrents if t.get("state") in ("uploading", "stalledUP", "forcedUP")]
            total_dl_speed = sum(t.get("dlspeed", 0) for t in downloading) / 1048576
            print(f"\n  {gold('Torrents')}   {len(downloading)} downloading ({total_dl_speed:.1f} MB/s), {len(seeding)} seeding, {len(torrents)} total")
        except Exception:
            pass

    # Disk
    print(bold("\n  Disk"))
    print(f"  {C.DIM}{'━' * 50}{C.RESET}")
    try:
        st = os.statvfs(MEDIA_PATH_WSL)
        total = st.f_blocks * st.f_frsize
        free = st.f_bavail * st.f_frsize
        used = total - free
        pct = (used / total) * 100
        bar_len = 25
        filled = int(bar_len * used / total)
        bar = "█" * filled + "░" * (bar_len - filled)
        color = ok if pct < 80 else (warn if pct < 90 else err)
        print(f"  D:\\Media  [{bar}] {color(f'{pct:.0f}%')}  {fmt_size(free)} free / {fmt_size(total)}")
    except Exception:
        print(f"  {err('Cannot read disk')}")

    print()

def cmd_doctor(fix=False):
    print_banner()
    print(f"\n  Running diagnostics across your entire media stack...\n")
    issues = []
    checks_passed = 0

    # 1. Service reachability with response times
    print(bold("  Service Connectivity"))
    print(f"  {C.DIM}{'━' * 50}{C.RESET}")

    # Pre-check: detect which Windows processes are running
    _win_processes = {}
    try:
        ps_result = subprocess.run(
            ["/mnt/c/Windows/System32/WindowsPowerShell/v1.0/powershell.exe", "-Command",
             "Get-Process | Select-Object Name,Id | Format-Table -HideTableHeaders"],
            capture_output=True, text=True, timeout=5
        )
        for line in ps_result.stdout.strip().split("\n"):
            parts = line.strip().split()
            if len(parts) >= 2:
                _win_processes[parts[0].lower()] = parts[1]
    except Exception:
        pass

    # Map service names to Windows process names
    _proc_names = {
        "sonarr": "sonarr", "radarr": "radarr", "prowlarr": "prowlarr",
        "plex": "plex media server", "tautulli": "tautulli",
        "qbittorrent": "qbittorrent",
    }
    # Which are actual Windows services (vs desktop apps)?
    _win_service_names = {
        "sonarr": "Sonarr", "radarr": "Radarr", "prowlarr": "Prowlarr",
        "plex": "Plex Media Server",
    }
    # Desktop apps (not Windows services — cannot use Restart-Service)
    _desktop_apps = {"qbittorrent", "tautulli"}

    for name, svc in SERVICES.items():
        host = svc["host"]
        port = svc["port"]
        svc_type = svc["type"]
        t0 = _time.time()
        up = check_reachable(name)
        elapsed = (_time.time() - t0) * 1000
        if up:
            checks_passed += 1
            speed = ok(f"{elapsed:.0f}ms")
            if elapsed > 2000:
                speed = warn(f"{elapsed:.0f}ms (slow)")
                issues.append(
                    f"SLOW SERVICE: {name} responded in {elapsed:.0f}ms (>2s). "
                    f"Type: {svc_type}. URL: http://{host}:{port}/. "
                    f"Fix: check {name} resource usage or network latency."
                )
            print(f"  {ok('✓')} {name:<15} {dim(f':{port}'):<12} {speed}")
        else:
            # Diagnose WHY it's unreachable
            diag = ""
            if svc_type == "docker":
                # Check container state
                try:
                    cr = subprocess.run(
                        ["docker", "inspect", "-f", "{{.State.Status}}", name],
                        capture_output=True, text=True, timeout=5
                    )
                    cstate = cr.stdout.strip()
                    if cstate == "running":
                        diag = f"Container is running but port {port} not responding. "
                        fix_hint = (
                            f"Fix: container '{name}' is running but not serving on port {port}. "
                            f"Check logs: docker logs --tail 30 {name}. "
                            f"Try restart: docker restart {name}"
                        )
                    elif cstate:
                        diag = f"Container state: {cstate}. "
                        fix_hint = f"Fix: run 'docker start {name}'. Check logs: docker logs --tail 30 {name}"
                    else:
                        fix_hint = f"Fix: container not found. Run 'docker ps -a | grep {name}'"
                except Exception:
                    fix_hint = f"Fix: run 'docker restart {name}' then verify at http://{host}:{port}/"
            else:
                # Check if Windows process is running
                proc_name = _proc_names.get(name, name)
                proc_running = any(proc_name in k for k in _win_processes)
                proc_pid = ""
                if proc_running:
                    for k, v in _win_processes.items():
                        if proc_name in k:
                            proc_pid = v
                            break

                if proc_running:
                    diag = f"Process IS running (PID {proc_pid}) but port {port} not reachable from WSL. "
                    if name in _desktop_apps:
                        fix_hint = (
                            f"Fix: {name} process is running (PID {proc_pid}) but http://{host}:{port}/ is not responding. "
                            f"This is a desktop app, NOT a Windows service (Restart-Service will NOT work). "
                            f"Possible causes: (1) Web UI is disabled in {name} settings, "
                            f"(2) bound to a different port, "
                            f"(3) Windows Firewall blocking port {port} from WSL — "
                            f"run: powershell New-NetFirewallRule -DisplayName '{name} WSL' -Direction Inbound -LocalPort {port} -Protocol TCP -Action Allow. "
                            f"(4) {name} Web UI bound to localhost only — change to 0.0.0.0 in {name} settings."
                        )
                    else:
                        win_svc = _win_service_names.get(name, name)
                        fix_hint = (
                            f"Fix: {name} process is running (PID {proc_pid}) but http://{host}:{port}/ is not responding. "
                            f"Try restarting the Windows service: powershell Restart-Service '{win_svc}' -Force. "
                            f"If that fails, check Windows Firewall: "
                            f"powershell New-NetFirewallRule -DisplayName '{name} WSL' -Direction Inbound -LocalPort {port} -Protocol TCP -Action Allow."
                        )
                else:
                    diag = f"Process NOT found running on Windows. "
                    if name in _desktop_apps:
                        fix_hint = (
                            f"Fix: {name} is not running. It is a desktop app (NOT a Windows service). "
                            f"Start it manually from the Windows Start Menu or its install directory. "
                            f"Common paths: C:\\Program Files\\{name}\\ or C:\\Users\\Max\\AppData\\."
                        )
                    else:
                        win_svc = _win_service_names.get(name, name)
                        fix_hint = (
                            f"Fix: {name} is not running. "
                            f"Start the Windows service: powershell Start-Service '{win_svc}'. "
                            f"If that fails, it may not be installed as a service — "
                            f"check: powershell Get-Service '{win_svc}'."
                        )

            issues.append(
                f"UNREACHABLE: {name} ({svc_type}) at http://{host}:{port}/ — {diag}{fix_hint}"
            )
            status_extra = ""
            if diag:
                short_diag = "process up, port blocked" if "IS running" in diag else "not running"
                status_extra = f" {dim(f'({short_diag})')}"
            print(f"  {err('✗')} {name:<15} {dim(f':{port}'):<12} {err('unreachable')} {dim(f'[{svc_type}]')}{status_extra}")

    # 2. API key validation
    print(bold("\n  API Keys"))
    print(f"  {C.DIM}{'━' * 50}{C.RESET}")
    key_configs = {
        "sonarr":   "/mnt/c/ProgramData/Sonarr/config.xml",
        "radarr":   "/mnt/c/ProgramData/Radarr/config.xml",
        "prowlarr": "/mnt/c/ProgramData/Prowlarr/config.xml",
        "plex":     "/mnt/c/Users/Max/AppData/Local/Plex/Plex Media Server/Preferences.xml",
        "tautulli": "/mnt/c/ProgramData/Tautulli/config.ini",
        "seerr":    "docker exec seerr cat /app/config/settings.json",
    }
    alt_paths = {
        "tautulli": [
            "/mnt/c/Users/Max/AppData/Local/Tautulli/config.ini",
            "/mnt/c/Users/Max/AppData/Roaming/Tautulli/config.ini",
        ],
        "sonarr": ["/mnt/c/Users/Max/AppData/Roaming/Sonarr/config.xml"],
        "radarr": ["/mnt/c/Users/Max/AppData/Roaming/Radarr/config.xml"],
    }
    for svc in ["sonarr", "radarr", "prowlarr", "plex", "tautulli", "seerr"]:
        key = get_key(svc)
        if key:
            checks_passed += 1
            masked = key[:4] + "…" + key[-4:] if len(key) > 8 else "****"
            print(f"  {ok('✓')} {svc:<15} {dim(masked)}")
        else:
            config_path = key_configs.get(svc, "unknown")
            alts = alt_paths.get(svc, [])
            # Check if any alt paths exist
            found_alt = None
            for alt in alts:
                if os.path.exists(alt):
                    found_alt = alt
                    break
            if found_alt:
                fix_hint = f"Config found at alternative path: {found_alt}. Update get_key() or create symlink."
            elif svc == "seerr":
                fix_hint = f"Read from Docker: {config_path}. Check container is running: docker ps | grep seerr"
            else:
                fix_hint = (
                    f"Expected config at: {config_path}. "
                    f"Alt paths to check: {', '.join(alts) if alts else 'none'}. "
                    f"Or get the API key from the {svc} web UI: Settings > General > API Key."
                )
            issues.append(
                f"API KEY MISSING: {svc} API key not found. {fix_hint}"
            )
            extra = ""
