        print(f"  {dim('No active downloads')}")

    if seeding:
        print(f"\n  {dim(f'{len(seeding)} seeding')}", end="")
    if paused:
        print(f"  {dim(f'{len(paused)} paused')}", end="")
    print(f"  {dim(f'{len(data)} total')}\n")

