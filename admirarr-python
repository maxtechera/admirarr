def cmd_restart(service):
    service = service.lower()
    docker_svcs = {"seerr", "bazarr", "organizr", "flaresolverr"}
    win_svcs = {
        "sonarr": "Sonarr", "radarr": "Radarr", "prowlarr": "Prowlarr",
        "plex": "Plex Media Server", "tautulli": "Tautulli"
    }

    if service in docker_svcs:
        print(f"  Restarting {service}...")
        result = subprocess.run(["docker", "restart", service], capture_output=True, text=True, timeout=30)
        if result.returncode == 0:
            print(f"  {ok('●')} Restarted {service}")
        else:
            print(f"  {err('Failed:')} {result.stderr}")
    elif service in win_svcs:
        print(f"  Restarting {service} (requires admin)...")
        cmd = f'/mnt/c/Windows/System32/cmd.exe /c "powershell -Command \\"Restart-Service \'{win_svcs[service]}\' -Force\\""'
        os.system(cmd)
        print(f"  {ok('●')} Restart command sent — verify with: admirarr status")
    else:
        print(f"  {err(f'Unknown service: {service}')}")
        print(f"  Available: {', '.join(sorted(docker_svcs | set(win_svcs.keys())))}")
    print()

def cmd_docker():
