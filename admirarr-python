def print_cmd_help(command):
    """Print detailed help for a specific command."""
    info = CMD_HELP.get(command)
    if not info:
        print(f"  {err(f'No help available for: {command}')}")
        return

    print(f"\n  {gold('⚓')} {bold('admirarr ' + command)}\n")
    print(f"  {info['summary']}\n")

    print(f"  {bold('USAGE')}")
    print(f"  {dim('$')} {info['usage']}\n")

    if info.get("flags"):
        print(f"  {bold('FLAGS')}")
        for flag, desc in info["flags"]:
            print(f"  {gold(f'{flag:<14}')} {desc}")
        print()

    print(f"  {bold('EXAMPLES')}")
    for ex in info["examples"]:
        print(f"  {dim('$')} {ex}")
    print()

    print(f"  {bold('DETAILS')}")
    for line in info["details"].strip().split("\n"):
        print(f"  {line}")
    print()

# ── Main ─────────────────────────────────────────────────────────────────────

def main():
    args = sys.argv[1:]
    if not args:
        cmd_help()
        return

    cmd = args[0].lower()

    # Handle <command> --help for any command
    if "--help" in args[1:] or "-h" in args[1:]:
        if cmd in CMD_HELP:
            print_cmd_help(cmd)
            return

    # Strip flags from rest for commands that take arguments
    rest_parts = [a for a in args[1:] if not a.startswith("--")]
    rest = " ".join(rest_parts)

    dispatch = {
        "status":    lambda: cmd_status(),
        "doctor":    lambda: cmd_doctor(fix=("--fix" in args)),
        "health":    lambda: cmd_health(),
        "movies":    lambda: cmd_movies(),
        "shows":     lambda: cmd_shows(),
        "downloads": lambda: cmd_downloads(),
        "queue":     lambda: cmd_queue(),
        "missing":   lambda: cmd_missing(),
        "search":    lambda: cmd_search(rest) if rest else print(err("  Usage: admirarr search <query>")),
        "add-movie": lambda: cmd_add_movie(rest) if rest else print(err("  Usage: admirarr add-movie <query>")),
        "add-show":  lambda: cmd_add_show(rest) if rest else print(err("  Usage: admirarr add-show <query>")),
        "find":      lambda: cmd_find(rest) if rest else print(err("  Usage: admirarr find <query>")),
        "indexers":  lambda: cmd_indexers(),
        "scan":      lambda: cmd_scan(),
        "recent":    lambda: cmd_recent(),
        "history":   lambda: cmd_history(),
        "restart":   lambda: cmd_restart(rest) if rest else print(err("  Usage: admirarr restart <service>")),
        "docker":    lambda: cmd_docker(),
        "disk":      lambda: cmd_disk(),
        "logs":      lambda: cmd_logs(rest) if rest else print(err("  Usage: admirarr logs <sonarr|radarr>")),
        "help":      lambda: cmd_help(),
        "--help":    lambda: cmd_help(),
        "-h":        lambda: cmd_help(),
        "--version": lambda: print(f"admirarr v{VERSION}"),
        "-v":        lambda: print(f"admirarr v{VERSION}"),
    }

    if cmd in dispatch:
        dispatch[cmd]()
    else:
        print(f"  {err(f'Unknown command: {cmd}')}")
        print(f"  Run {gold('admirarr help')} for usage information.\n")

if __name__ == "__main__":
    main()
