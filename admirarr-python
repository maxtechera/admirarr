def cmd_disk():
    print_banner()
    print(bold("\n  Disk Space\n"))
    for path, label in [(MEDIA_PATH_WSL, "D:\\Media"), (MEDIA_PATH_WSL + "/Downloads", "Downloads"), (MEDIA_PATH_WSL + "/Movies", "Movies"), (MEDIA_PATH_WSL + "/TV Shows", "TV Shows")]:
        try:
            st = os.statvfs(path)
            total = st.f_blocks * st.f_frsize
            free = st.f_bavail * st.f_frsize
            used = total - free
            count = sum(1 for _ in Path(path).rglob("*") if _.is_file())
            print(f"  {label:<15} {fmt_size(used):>10} used / {fmt_size(total):>10} total  ({count} files)")
        except Exception:
            print(f"  {label:<15} {err('N/A')}")
    print()

def cmd_logs(service):
