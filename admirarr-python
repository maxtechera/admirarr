            data = json.loads(resp.read().decode())
    except Exception:
        print(f"  {err('Cannot reach qBittorrent')}")
        return

    downloading = [t for t in data if t.get("state") in ("downloading", "stalledDL", "forcedDL", "metaDL")]
    seeding = [t for t in data if t.get("state") in ("uploading", "stalledUP", "forcedUP")]
    paused = [t for t in data if "paused" in t.get("state", "")]

    if downloading:
        print(bold("  Active Downloads"))
        for t in downloading:
            pct = int(t.get("progress", 0) * 100)
            speed = t.get("dlspeed", 0) / 1048576
            size = fmt_size(t.get("size", 0))
            bar_len = 15
            filled = int(bar_len * pct / 100)
