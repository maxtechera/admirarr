def cmd_add_movie(query):
    print_banner()
    print(bold(f"\n  Search Radarr: {query}\n"))
    results = api_get("radarr", "api/v3/movie/lookup", {"term": query})
    if not results or len(results) == 0:
        print(f"  {err('No results')}")
        return
    for i, m in enumerate(results[:5], 1):
        print(f"  {gold(str(i))}. {m['title']} ({m.get('year', '?')})")
        overview = (m.get("overview") or "")[:80]
        if overview:
            print(f"     {dim(overview)}")

    try:
        choice = input(f"\n  Pick [1-{min(5, len(results))}] or q to cancel: ").strip()
        if choice.lower() == "q":
            return
        idx = int(choice) - 1
        movie = results[idx]
    except (ValueError, IndexError, EOFError):
        print(f"  {err('Invalid choice')}")
        return

    roots = api_get("radarr", "api/v3/rootfolder")
    profiles = api_get("radarr", "api/v3/qualityprofile")
    if not roots or not profiles:
        print(f"  {err('Cannot get Radarr config')}")
        return

    movie["qualityProfileId"] = profiles[0]["id"]
    movie["rootFolderPath"] = roots[0]["path"]
    movie["monitored"] = True
    movie["addOptions"] = {"searchForMovie": True}

    result = api_post("radarr", "api/v3/movie", movie)
    if result and isinstance(result, dict) and result.get("id"):
        print(f"\n  {ok('Added:')} {result['title']} ({result.get('year', '?')}) — searching...")
    else:
        print(f"\n  {err('Failed to add.')} Response: {str(result)[:100]}")
    print()

