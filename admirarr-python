def _doctor_fix(issues):
    """Interactive fix wizard: user picks AI agent, reviews prompt, then streams fixes."""

    # Detect available AI CLI agents
    agents = []
    agent_cmds = {
        "claude":   {"name": "Claude Code",  "flag": "-p", "tools_flag": "--allowedTools Bash"},
        "opencode": {"name": "OpenCode",     "flag": "-p", "tools_flag": ""},
        "aider":    {"name": "Aider",        "flag": "--message", "tools_flag": ""},
        "goose":    {"name": "Goose",        "flag": "-m", "tools_flag": ""},
    }

    for cmd, info in agent_cmds.items():
        try:
            result = subprocess.run(
                [cmd, "--version"], capture_output=True, text=True, timeout=5
            )
            if result.returncode == 0:
                ver = result.stdout.strip().split("\n")[0][:40]
                agents.append({"cmd": cmd, **info, "version": ver})
        except Exception:
            pass

    if not agents:
        print(f"  {err('✗')} No AI agent CLI found. Install one of:")
        print(f"    {dim('Claude Code:')}  npm install -g @anthropic-ai/claude-code")
        print(f"    {dim('OpenCode:')}     go install github.com/opencode-ai/opencode@latest")
        print(f"    {dim('Aider:')}        pip install aider-chat")
        print(f"    {dim('Goose:')}        pip install goose-ai")
        return

    # Step 1: Let user pick the agent
    print(f"\n  {dim('━' * 50)}")
    print(f"  {gold('⚓')} {bold('Fix Wizard')} — select your AI agent\n")

    if len(agents) == 1:
        agent = agents[0]
        print(f"  Using {bold(agent['name'])} {dim(agent['version'])}")
    else:
        for i, a in enumerate(agents, 1):
            print(f"  {gold(str(i))}. {a['name']}  {dim(a['version'])}")
        print()
        try:
            choice = input(f"  Select agent [{gold('1')}]: ").strip() or "1"
            idx = int(choice) - 1
            if idx < 0 or idx >= len(agents):
                idx = 0
            agent = agents[idx]
        except (ValueError, EOFError, KeyboardInterrupt):
            agent = agents[0]
            print()

    print(f"\n  {ok('✓')} Selected: {bold(agent['name'])}\n")

    # Step 2: Build the prompt
    issue_list = "\n".join(f"  {i+1}. {iss}" for i, iss in enumerate(issues))

    prompt = f"""You are the admirarr doctor fix wizard for a Plex + *Arr media server stack.

ENVIRONMENT:
- Windows host IP: {WIN_HOST}
- Media path (WSL): {MEDIA_PATH_WSL}  |  Media path (Windows): {MEDIA_PATH_WIN}
- Docker containers: seerr, bazarr, organizr, flaresolverr
- Windows services: Sonarr, Radarr, Prowlarr, "Plex Media Server", Tautulli, qBittorrent

DETECTED ISSUES:
{issue_list}

FIX INSTRUCTIONS:
- Service unreachable (Docker): docker restart <name>, verify with curl
- Service unreachable (Windows): /mnt/c/Windows/System32/cmd.exe /c "powershell -Command \\"Restart-Service '<Name>' -Force\\""
- API key not found: read from /mnt/c/ProgramData/<Service>/config.xml, or guide user to Settings > General in the web UI
- Config missing: check alternative paths under /mnt/c/Users/*/AppData/
- Media path missing: mkdir -p <path>
- Disk space: report usage, suggest cleanup — DO NOT delete anything
- Docker container down: docker start <name>
- Indexer failures: check FlareSolverr (curl http://localhost:8191/v1), report Prowlarr status
- *Arr health warnings: explain and provide fix commands

For each issue print:
  Fixing: <description>
  Action: <command or step>
  Result: <outcome>

Fix what you can automatically. For manual steps, provide exact commands."""

    # Step 3: Show prompt and get confirmation
    print(f"  {bold('Draft prompt:')}")
    print(f"  {dim('─' * 50)}")
    for line in prompt.strip().split("\n"):
        print(f"  {dim('│')} {line}")
    print(f"  {dim('─' * 50)}\n")

    try:
        confirm = input(f"  Run this fix? [{gold('Y')}/n/edit]: ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print(f"\n  {dim('Cancelled.')}")
        return

    if confirm == "n":
        print(f"  {dim('Cancelled.')}")
        return
    elif confirm == "edit":
        print(f"\n  {dim('Paste your modified prompt (end with an empty line):')}")
        lines = []
        try:
            while True:
                line = input()
                if line == "":
                    break
                lines.append(line)
        except (EOFError, KeyboardInterrupt):
            pass
        if lines:
            prompt = "\n".join(lines)
            print(f"  {ok('✓')} Using custom prompt\n")
        else:
            print(f"  {dim('No changes — using original prompt')}\n")

    # Step 4: Stream the fix
    print(f"  {dim('━' * 50)}")
    print(f"  {gold('⚓')} Streaming fixes via {bold(agent['name'])}...\n")

    cmd_parts = [agent["cmd"], agent["flag"], prompt]
    if agent["tools_flag"]:
        cmd_parts.extend(agent["tools_flag"].split())

    try:
        proc = subprocess.Popen(
            cmd_parts,
            stdout=subprocess.PIPE, stderr=subprocess.PIPE,
            text=True, bufsize=1
        )
        for line in iter(proc.stdout.readline, ""):
            print(f"  {line}", end="")
        proc.wait(timeout=180)

        if proc.returncode != 0:
            stderr_out = proc.stderr.read().strip()
            if stderr_out:
                print(f"\n  {err('Error:')} {stderr_out[:200]}")
    except subprocess.TimeoutExpired:
        proc.kill()
        print(f"\n  {err('Fix wizard timed out (180s)')}")
    except Exception as e:
        agent_name = agent["name"]
        print(f"\n  {err(f'Failed to run {agent_name}: {e}')}")

    print(f"\n  {dim('━' * 50)}")
    print(f"  {dim('Re-run')} {gold('admirarr doctor')} {dim('to verify fixes.')}")

